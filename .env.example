NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5173

DATABASE_URL=postgresql://user:password@localhost:5432/tailor_db

REDIS_URL=redis://localhost:6379

# Generate with:
#   openssl genrsa -out keys/private.pem 2048
#   openssl rsa -in keys/private.pem -pubout -out keys/public.pem
# Then paste the PEM content with \n replacing actual newlines
JWT_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----
JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----
JWT_ACCESS_TOKEN_TTL=900
JWT_REFRESH_TOKEN_TTL=2592000

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3001/api/auth/github/callback

FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_CALLBACK_URL=http://localhost:3001/api/auth/facebook/callback

APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
APPLE_CALLBACK_URL=http://localhost:3001/api/auth/apple/callback

LLM_PROVIDER=openai
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6
LLM_REQUEST_TIMEOUT_MS=60000
LLM_PROMPT_VERSION=v1.0

ANALYSIS_WORKER_CONCURRENCY=3
ANALYSIS_MAX_FILE_SIZE_BYTES=10485760
ANALYSIS_MAX_TEXT_CHARS=50000

THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=200
ANALYSIS_THROTTLE_TTL_MS=900000
ANALYSIS_THROTTLE_LIMIT_ANON=10
ANALYSIS_THROTTLE_LIMIT_USER=30
